  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\creating clean_dim_payment"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{FA41A616-9F11-4867-88C5-B11DAD24AEE5}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="creating clean_dim_payment"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="1">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{F8147821-6AFD-4D8A-AD56-86A55577A176}"
          SQLTask:SqlStatementSource="drop table if exists [stg_bright_retail].[dbo].[clean_payment];&#xA;go&#xA;&#xA;if object_id ('[stg_bright_retail].[dbo].[clean_payment]', 'U') is null&#xA;begin&#xA;    create table [stg_bright_retail].[dbo].[clean_payment] (&#xA;        payment_id int identity(1,1) primary key,&#xA;        payment_method varchar(250) not null&#xA;    );&#xA;end&#xA;go" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\creating clean_dim_store"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{3CFDDFA5-6D54-469A-9DC7-24578D87CCD2}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="creating clean_dim_store"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{F8147821-6AFD-4D8A-AD56-86A55577A176}"
          SQLTask:SqlStatementSource="if object_id('[stg_bright_retail].[dbo].[clean_store]', 'u') is null&#xA;begin&#xA;    create table [stg_bright_retail].[dbo].[clean_store] (&#xA;        store_key             int identity(1,1) primary key,&#xA;        store_id              int not null,&#xA;        store_name            varchar(250) not null,&#xA;        store_province        varchar(250) not null,&#xA;        store_region          varchar(50)  not null,&#xA;        store_manager         varchar(100) not null,&#xA;        effective_start_date  date not null,&#xA;        effective_end_date    date null,&#xA;        is_current            bit not null&#xA;    );&#xA;end&#xA;go" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\loadind and cleaning dim_store"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{A677B9A3-C91E-4384-8109-BCD428F3F995}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="loadind and cleaning dim_store"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{F8147821-6AFD-4D8A-AD56-86A55577A176}"
          SQLTask:SqlStatementSource="update s&#xA;set s.effective_end_date = getdate(), s.is_current = 0&#xA;from [stg_bright_retail].[dbo].[clean_store] s&#xA;join (&#xA;    select distinct ltrim(rtrim(store_name)) as store_name, ltrim(rtrim(store_manager)) as store_manager&#xA;    from [stg_bright_retail].[dbo].[bright_retail_raw_data]&#xA;) b&#xA;    on s.store_name = b.store_name&#xA;where s.is_current = 1 and s.store_manager &lt;&gt; s.store_manager;&#xA;go&#xA;&#xA;&#xA;insert into [stg_bright_retail].[dbo].[clean_store] (&#xA;    store_id, store_name, store_province, store_region, store_manager,&#xA;    effective_start_date, effective_end_date, is_current&#xA;)&#xA;select&#xA;    row_number() over (order by b.store_name) + isnull((select max(store_id) from [stg_bright_retail].[dbo].[clean_store]), 0),&#xA;    b.store_name, b.store_province, b.store_region, b.store_manager,&#xA;    cast(getdate() as date), null, 1&#xA;from (&#xA;    select distinct&#xA;        ltrim(rtrim(store_name)) as store_name,&#xA;        ltrim(rtrim(store_province)) as store_province,&#xA;        ltrim(rtrim(store_region)) as store_region,&#xA;        ltrim(rtrim(store_manager)) as store_manager&#xA;    from [stg_bright_retail].[dbo].[bright_retail_raw_data]&#xA;) as b&#xA;where not exists (&#xA;    select 1 from [stg_bright_retail].[dbo].[clean_store] s where s.store_name = b.store_name and s.is_current = 1&#xA;);&#xA;go" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\loading and cleaning dim_payment"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{A714E715-D3A5-4F8C-A380-68219D58AA37}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="loading and cleaning dim_payment"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="1">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{F8147821-6AFD-4D8A-AD56-86A55577A176}"
          SQLTask:SqlStatementSource="insert into [stg_bright_retail].[dbo].[clean_payment] (payment_method)&#xA;select distinct&#xA;        case upper(ltrim(rtrim(payment_method)))&#xA;            when 'CASH'         then 'Cash'&#xA;            when 'CREDIT CARD'  then 'Credit Card'&#xA;            when 'DEBIT CARD'   then 'Debit Card'&#xA;            when 'EFT'          then 'EFT'&#xA;            when 'STORE CREDIT' then 'Store Credit'&#xA;            else ltrim(rtrim(payment_method))&#xA;        end as payment_method&#xA;    from [stg_bright_retail].[dbo].[bright_retail_raw_data]&#xA;as s&#xA;where not exists (&#xA;    select 1 from [stg_bright_retail].[dbo].[clean_payment] d where d.payment_method = s.payment_method&#xA;);&#xA;go&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
