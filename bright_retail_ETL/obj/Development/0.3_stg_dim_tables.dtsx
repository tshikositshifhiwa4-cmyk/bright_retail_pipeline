          SQLTask:SqlStatementSource="if object_id ('[stg_bright_retail].[dbo].[dim_payment]', 'U') is null&#xA;begin&#xA;    create table [stg_bright_retail].[dbo].[dim_payment] (&#xA;        payment_id int identity(1,1) primary key,&#xA;        payment_method varchar(250) &#xA;    );&#xA;end &#xA;go" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
