          SQLTask:SqlStatementSource="truncate table  [stg_bright_retail].[dbo].[dim_payment]&#xA;&#xA;insert into [stg_bright_retail].[dbo].[dim_payment] (payment_method)&#xA;&#xA;select distinct payment_method&#xA;from [stg_bright_retail].[dbo].[bright_retail_raw_data];&#xA;go" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
