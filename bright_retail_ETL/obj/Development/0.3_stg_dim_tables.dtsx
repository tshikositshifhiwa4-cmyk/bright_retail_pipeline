          SQLTask:SqlStatementSource="truncate table [stg_bright_retail].[dbo].[dim_product]&#xA;&#xA;&#xA;insert into [stg_bright_retail].[dbo].[dim_product] (&#xA;     product_name, category, sub_category, sku&#xA;)&#xA;&#xA;&#xA;&#xA;select distinct &#xA;     product_name, &#xA;     category, &#xA;     sub_category, &#xA;     sku&#xA;from stg_bright_retail.dbo.bright_retail_raw_data&#xA;;&#xA;&#xA;go" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
