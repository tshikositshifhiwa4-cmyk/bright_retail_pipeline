    <DTS:Executable
      DTS:refId="Package\loading dim_date"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{FEBDFF20-AFCB-4F43-82C7-3439AF0A84CB}"
