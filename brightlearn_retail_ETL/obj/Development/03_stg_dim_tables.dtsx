      DTS:ThreadHint="3">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{530DB872-1956-4B71-8BD1-2BC73FF88A8F}"
          SQLTask:SqlStatementSource="insert into [stg_bright_retail].[dbo].[dim_product] (&#xA;    product_name, category, sub_category, sku&#xA;)&#xA;select s.product_name, s.category, s.sub_category, s.sku&#xA;from (&#xA;    select distinct product_name, category, sub_category, sku&#xA;    from stg_bright_retail.dbo.bright_retail_raw_data&#xA;) as s&#xA;where not exists (&#xA;    select 1 from [stg_bright_retail].[dbo].[dim_product] d where d.sku = s.sku&#xA;);&#xA;go&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\loading 06_dim_cashier"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{1782EAF3-44E9-4D33-951A-C6DA4799289B}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="loading 06_dim_cashier"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="4">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{530DB872-1956-4B71-8BD1-2BC73FF88A8F}"
          SQLTask:SqlStatementSource="insert into [stg_bright_retail].[dbo].[dim_cashier] (cashier_name)&#xA;select s.cashier_name&#xA;from (&#xA;    select distinct cashier_name&#xA;    from stg_bright_retail.dbo.bright_retail_raw_data&#xA;) as s&#xA;where not exists (&#xA;    select 1 from [stg_bright_retail].[dbo].[dim_cashier] d where d.cashier_name = s.cashier_name&#xA;);&#xA;go&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\loading 07_dim_date"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{14BE8676-A362-4558-BF2F-1D26AF629704}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="loading 07_dim_date"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="5">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{530DB872-1956-4B71-8BD1-2BC73FF88A8F}"
          SQLTask:SqlStatementSource="insert into [stg_bright_retail].[dbo].[dim_date] (transaction_date, month_name, month)&#xA;select&#xA;    s.clean_date,&#xA;    datename(month, s.clean_date),&#xA;    month(s.clean_date)&#xA;from (&#xA;    select distinct try_convert(date, transaction_date) as clean_date&#xA;    from stg_bright_retail.dbo.bright_retail_raw_data&#xA;) as s&#xA;where s.clean_date is not null&#xA;  and not exists (&#xA;      select 1 from [stg_bright_retail].[dbo].[dim_date] d where d.transaction_date = s.clean_date&#xA;  );&#xA;go" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
