    <DTS:Executable
      DTS:refId="Package\loading 01_dim_payment"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{C54797C9-B83A-4C78-B64F-8269A7FA7FD0}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="loading 01_dim_payment"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="6">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{530DB872-1956-4B71-8BD1-2BC73FF88A8F}"
          SQLTask:SqlStatementSource="insert into [stg_bright_retail].[dbo].[dim_payment] (payment_method)&#xA;select s.payment_method&#xA;from (&#xA;    select distinct payment_method&#xA;    from [stg_bright_retail].[dbo].[bright_retail_raw_data]&#xA;) as s&#xA;where not exists (&#xA;    select 1 from [stg_bright_retail].[dbo].[dim_payment] d where d.payment_method = s.payment_method&#xA;);&#xA;go&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\loading 02_dim_store"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{55A873A0-23E0-42F8-8306-37D38B92B7D1}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="loading 02_dim_store"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{530DB872-1956-4B71-8BD1-2BC73FF88A8F}"
          SQLTask:SqlStatementSource="update s&#xA;set s.effective_end_date = getdate(), s.is_current = 0&#xA;from [stg_bright_retail].[dbo].[dim_store] as s&#xA;join (select distinct store_name, store_manager from [stg_bright_retail].[dbo].[bright_retail_raw_data]) as b&#xA;    on s.store_name = b.store_name&#xA;where s.is_current = 1 and s.store_manager &lt;&gt; b.store_manager;&#xA;go&#xA;&#xA;insert into [stg_bright_retail].[dbo].[dim_store] (&#xA;    store_id, store_name,store_city, store_province, store_region, store_manager,&#xA;    effective_start_date, effective_end_date, is_current&#xA;)&#xA;select&#xA;    row_number() over (order by b.store_name) + isnull((select max(store_id) from [stg_bright_retail].[dbo].[dim_store]), 0) as store_id,&#xA;    b.store_name,&#xA;    b.store_city,&#xA;    b.store_province,&#xA;    b.store_region,&#xA;    b.store_manager,&#xA;    cast(getdate() as date) as effective_start_date,&#xA;    null as effective_end_date,&#xA;    1 as is_current&#xA;from (&#xA;    select distinct store_name, store_city, store_province, store_region, store_manager&#xA;    from [stg_bright_retail].[dbo].[bright_retail_raw_data]&#xA;) as b&#xA;where not exists (&#xA;    select 1&#xA;    from [stg_bright_retail].[dbo].[dim_store] as s&#xA;    where b.store_name = s.store_name&#xA;      and s.is_current = 1&#xA;);&#xA;go" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\loading 03_dim_supplier"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{0A6223A0-5CCE-450B-A107-E2B8544ACE74}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="loading 03_dim_supplier"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="1">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{530DB872-1956-4B71-8BD1-2BC73FF88A8F}"
          SQLTask:SqlStatementSource="insert into [stg_bright_retail].[dbo].[dim_supplier] (supplier)&#xA;select s.supplier&#xA;from (&#xA;    select distinct supplier&#xA;    from stg_bright_retail.dbo.bright_retail_raw_data&#xA;) as s&#xA;where not exists (&#xA;    select 1 from [stg_bright_retail].[dbo].[dim_supplier] d where d.supplier = s.supplier&#xA;);&#xA;go" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\loading 04_dim_customer"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{8B933633-A867-4805-A6D6-3B7B142B8C6F}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="loading 04_dim_customer"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="2">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{530DB872-1956-4B71-8BD1-2BC73FF88A8F}"
          SQLTask:SqlStatementSource="update c&#xA;set c.effective_end_date = getdate(),&#xA;    c.is_current = 0&#xA;from [stg_bright_retail].[dbo].[dim_customer] as c&#xA;join (&#xA;    select customer_email, customer_loyalty_tier,&#xA;           row_number() over (partition by customer_email order by customer_first_name) as rn&#xA;    from [stg_bright_retail].[dbo].[bright_retail_raw_data]&#xA;) as b&#xA;    on c.email = b.customer_email&#xA;where b.rn = 1&#xA;  and c.is_current = 1&#xA;  and c.loyalty_tier &lt;&gt; b.customer_loyalty_tier;&#xA;go&#xA;&#xA;insert into [stg_bright_retail].[dbo].[dim_customer] (&#xA;    customer_id, first_name, last_name, email, phone_number,&#xA;    loyalty_tier, customer_since, customer_city, customer_province,&#xA;    effective_start_date, effective_end_date, is_current&#xA;)&#xA;select&#xA;    row_number() over (order by b.customer_email) + isnull((select max(customer_id) from [stg_bright_retail].[dbo].[dim_customer]), 0),&#xA;    b.customer_first_name,&#xA;    b.customer_last_name,&#xA;    b.customer_email,&#xA;    b.customer_phone,&#xA;    b.customer_loyalty_tier,&#xA;    cast(b.customer_since as date),&#xA;    b.customer_city,&#xA;    b.customer_province,&#xA;    cast(getdate() as date),&#xA;    null,&#xA;    1&#xA;from (&#xA;    select&#xA;        customer_first_name, customer_last_name, customer_email,&#xA;        customer_phone, customer_loyalty_tier, customer_since,&#xA;        customer_city, customer_province,&#xA;        row_number() over (partition by customer_email order by customer_first_name) as rn&#xA;    from [stg_bright_retail].[dbo].[bright_retail_raw_data]&#xA;) as b&#xA;where b.rn = 1&#xA;  and not exists (&#xA;      select 1&#xA;      from [stg_bright_retail].[dbo].[dim_customer] as c&#xA;      where c.email = b.customer_email&#xA;        and c.is_current = 1&#xA;  );&#xA;go&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\loading 05_dim_product"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{45387927-97BC-4220-97CC-5FA8AE92FA3F}"
