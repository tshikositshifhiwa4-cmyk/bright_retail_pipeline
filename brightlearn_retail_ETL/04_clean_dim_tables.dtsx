          SQLTask:Connection="{530DB872-1956-4B71-8BD1-2BC73FF88A8F}"
          SQLTask:SqlStatementSource="if object_id('[stg_bright_retail].[dbo].[clean_date]', 'u') is null&#xA;begin&#xA;    create table [stg_bright_retail].[dbo].[clean_date] (&#xA;        date_id           int identity(1,1) primary key,&#xA;        transaction_date  date not null,&#xA;        month_name        varchar(20) not null,&#xA;        month             int not null&#xA;    );&#xA;end&#xA;go" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
